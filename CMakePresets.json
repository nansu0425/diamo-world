{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "ninja-msvc",
      "displayName": "Ninja Multi-Config + MSVC",
      "description": "Run inside Developer PowerShell for VS 2026. cl/cmake/ninja are discovered on PATH.",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",   "configurePreset": "ninja-msvc", "configuration": "Debug" },
    { "name": "release", "configurePreset": "ninja-msvc", "configuration": "Release" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "ninja-msvc",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "ninja-msvc",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
