#!/bin/sh
# Conventional Commits validator. Self-made, no third-party dependency.
# Enforces the structural rules of the Commit messages convention in CONTRIBUTING.md.

msgFile="$1"
subject=$(sed -n '1p' "$msgFile")
secondLine=$(sed -n '2p' "$msgFile")

# Skip messages git generates or templates we do not hand-author.
case "$subject" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*) exit 0 ;;
esac

types='feat|fix|refactor|perf|docs|test|build|ci|chore|style'

fail() {
  printf 'commit-msg: %s\n\n' "$1" >&2
  printf 'Commit messages follow Conventional Commits (see CONTRIBUTING.md):\n' >&2
  printf '  <type>(<scope>): <subject>\n' >&2
  printf '  types: %s\n' "$types" >&2
  printf '  example: feat(engine): add a fixed-step world tick\n' >&2
  exit 1
}

printf '%s' "$subject" | grep -Eq "^($types)(\([a-z0-9-]+\))?!?: .+" \
  || fail 'subject must match "<type>(<scope>): <subject>"'

[ "${#subject}" -le 72 ] || fail 'subject exceeds 72 characters'

case "$subject" in
  *.) fail 'subject must not end with a period' ;;
esac

[ -z "$secondLine" ] || fail 'leave a blank line between the subject and the body'

exit 0
